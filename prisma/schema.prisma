// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  password           String
  firstName          String?
  lastName           String?
  employeeCode       String?   @unique
  mobile             String?
  designation        String?
  departmentId       String?
  department         Department? @relation(fields: [departmentId], references: [id])
  roles              Role[]
  reportingManagerId String?
  reportingManager   User?     @relation("ManagerToSubordinates", fields: [reportingManagerId], references: [id])
  subordinates       User[]    @relation("ManagerToSubordinates")
  approverId         String?
  approver           User?     @relation("ApproverToApprovees", fields: [approverId], references: [id])
  approvees          User[]    @relation("ApproverToApprovees")
  locationId         String?
  location           Location?  @relation(fields: [locationId], references: [id])
  loginAccess        Boolean   @default(true)
  lastLogin          DateTime?
  isActive           Boolean   @default(true)
  status             String    @default("Active") // Active, Inactive
  deletedAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  auditLogs          AuditLog[]
  assignedLeads      Lead[]
  assignedTickets    Ticket[]
  todos              Todo[]    @relation("TodoAssignees")
  assignedCustomers  Customer[] @relation("CustomerAssignee")
  assignedContacts   Contact[]  @relation("ContactAssignee")
  createdBills        VendorBill[]        @relation("BillCreator")
  createdBillPayments VendorBillPayment[] @relation("BillPaymentCreator")
  managedWarehouses   Warehouse[]         @relation("WarehouseManager")
  createdMovements    StockMovement[]     @relation("MovementCreator")
  approvedAdjustments InventoryAdjustment[] @relation("AdjustmentApprover")

  @@map("users")
}

model Department {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("departments")
}

model Location {
  id          String           @id @default(uuid())
  name        String           @unique
  address     String?
  isActive    Boolean          @default(true)
  users       User[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("locations")
}

model UserInvitation {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  departmentId String
  roleId       String
  token        String?  @unique
  status       String   @default("Pending") // Pending, Accepted, Expired
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("user_invitations")
}

model TodoGroup {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  color       String?  @default("blue")
  todos       Todo[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("todo_groups")
}

model Todo {
  id          String    @id @default(uuid())
  title       String
  description String?   @db.Text
  priority    String    @default("Medium") // Low, Medium, High, Urgent
  status      String    @default("Pending") // Pending, In Progress, Completed, Cancelled
  dueDate     DateTime?
  groupId     String?
  group       TodoGroup? @relation(fields: [groupId], references: [id])
  assignees   User[]    @relation("TodoAssignees")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("todos")
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  permissions RolePermission[]
  users       User[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  module      String
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value String @db.Text
  group String @default("general")

  @@map("settings")
}

model Category {
  id          String    @id @default(uuid())
  name        String
  type        String    // e.g., "expense", "income"
  description String?
  isActive    Boolean   @default(true)
  expenses    Expense[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("categories")
}

model Expense {
  id             String    @id @default(uuid())
  amount         Float
  date           DateTime
  description    String?
  categoryId     String
  category       Category  @relation(fields: [categoryId], references: [id])
  status         String    @default("draft") // draft, pending, approved, rejected
  paymentMethod  String?   // Cash, Bank Transfer, Credit Card, etc.
  merchant       String?
  reference      String?
  receiptUrl     String?
  approvedBy     String?
  approvalDate   DateTime?
  rejectionReason String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("expenses")
}

model LedgerEntry {
  id          String   @id @default(uuid())
  date        DateTime @default(now())
  description String
  type        String   @default("expense") // income, expense
  debit       Float    @default(0)
  credit      Float    @default(0)
  balance     Float
  reference   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("ledger_entries")
}

model Activity {
  id        String   @id @default(uuid())
  type      String   // Created, Updated, PO_Created, Bill_Generated, Payment_Recorded
  message   String
  vendorId  String?
  vendor    Vendor?  @relation(fields: [vendorId], references: [id])
  userId    String?
  entityId  String?  // ID of the related object (PO, Bill, etc)
  createdAt DateTime @default(now())
  @@map("activities")
}

model InventoryCategory {
  id          String      @id @default(uuid())
  name        String      @unique
  description String?
  products    Inventory[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("inventory_categories")
}

model Warehouse {
  id          String           @id @default(uuid())
  name        String           @unique
  location    String?
  managerId   String?
  manager     User?            @relation("WarehouseManager", fields: [managerId], references: [id])
  products    Inventory[]
  movements   StockMovement[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("warehouses")
}

model Inventory {
  id            String    @id @default(uuid())
  sku           String    @unique
  name          String
  description   String?   @db.Text
  categoryId    String?
  category      InventoryCategory? @relation(fields: [categoryId], references: [id])
  vendorId      String?
  vendor        Vendor?   @relation(fields: [vendorId], references: [id])
  costPrice     Float     @default(0)
  sellingPrice  Float     @default(0)
  currentStock  Int       @default(0)
  minimumStock  Int       @default(10)
  reorderLevel  Int       @default(15)
  unit          String    @default("pc") // pc, kg, ltr, box, etc.
  status        String    @default("In Stock") // In Stock, Low Stock, Out of Stock, Overstocked
  warehouseId   String?
  warehouse     Warehouse? @relation(fields: [warehouseId], references: [id])
  
  movements     StockMovement[]
  adjustments   InventoryAdjustment[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("inventory_products")
}

model StockMovement {
  id            String    @id @default(uuid())
  productId     String
  product       Inventory @relation(fields: [productId], references: [id])
  warehouseId   String?
  warehouse     Warehouse? @relation(fields: [warehouseId], references: [id])
  type          String    // IN, OUT, ADJUSTMENT, TRANSFER
  quantity      Int
  referenceType String?   // PURCHASE_ORDER, SALES_ORDER, MANUAL, INVOICE, BILL, ADJUSTMENT
  referenceId   String?
  cost          Float?    // Unit cost at the time of movement
  notes         String?   @db.Text
  createdBy     String?
  creator       User?     @relation("MovementCreator", fields: [createdBy], references: [id])
  date          DateTime  @default(now())

  @@map("inventory_movements")
}

model InventoryAdjustment {
  id            String    @id @default(uuid())
  productId     String
  product       Inventory @relation(fields: [productId], references: [id])
  oldQty        Int
  newQty        Int
  difference    Int
  reason        String
  approvedBy    String?
  approver      User?     @relation("AdjustmentApprover", fields: [approvedBy], references: [id])
  notes         String?   @db.Text
  createdAt     DateTime  @default(now())

  @@map("inventory_adjustments")
}

model Vendor {
  id                  String   @id @default(uuid())
  name                String   @unique
  contactPerson       String?
  email               String?
  phone               String?
  website             String?
  taxNumber           String?
  currency            String   @default("USD")
  paymentTerms        Int      @default(30)
  billingAddressLine1 String?
  billingAddressLine2 String?
  city                String?
  state               String?
  country             String?
  postcode            String?
  status              String   @default("Active") // Active, Inactive
  purchaseOrders      PurchaseOrder[]
  bills               VendorBill[]
  inventory           Inventory[]
  activities          Activity[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  @@map("vendors")
}

model Lead {
  id              String   @id @default(uuid())
  title           String
  companyName     String
  contactPerson   String
  email           String?
  phone           String?
  source          String?  // Website, Referral, etc.
  pipelineStage   String   @default("New")
  value           Float    @default(0)
  assignedUserId  String?
  assignedUser    User?    @relation(fields: [assignedUserId], references: [id])
  priority        String   @default("Medium") // Low, Medium, High
  notes           String?  @db.Text
  expectedCloseDate DateTime?
  tags            String[] @default([])
  status          String   @default("Open")
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("leads")
}

model Customer {
  id              String   @id @default(uuid())
  name            String
  email           String?
  phone           String?
  type            String   @default("Company") // Company, Individual
  status          String   @default("Active") // Active, Inactive, Lead, Prospect
  source          String?  // Website, Referral, Direct, Cold Call, Partner
  assignedUserId  String?
  assignedUser    User?    @relation(fields: [assignedUserId], references: [id], name: "CustomerAssignee")
  companyName     String?
  nextFollowUp    DateTime?
  notes           String?  @db.Text
  address         String?  @db.Text
  contacts        Contact[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("customers")
}

model Contact {
  id              String   @id @default(uuid())
  firstName       String
  lastName        String
  email           String?
  phone           String?
  altPhone        String?
  jobTitle        String?
  department      String?
  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id])
  status          String    @default("Active") // Active, Inactive, Archived
  isPrimary       Boolean   @default(false)
  type            String    @default("Individual") // Individual, Agent, Contractor, Partner
  assignedUserId  String?
  assignedUser    User?     @relation(fields: [assignedUserId], references: [id], name: "ContactAssignee")
  preferredCommunication String? @default("Email")
  tags            String[]  @default([])
  followUpDate    DateTime?
  address         String?   @db.Text
  notes           String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("contacts")
}

model Ticket {
  id              String   @id @default(uuid())
  subject         String
  customerId      String?
  customerName    String?  // If not linked to Customer
  department      String
  priority        String   @default("Medium")
  status          String   @default("Open")
  assignedUserId  String?
  assignedUser    User?    @relation(fields: [assignedUserId], references: [id])
  description     String   @db.Text
  attachmentUrl   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("tickets")
}

model Invoice {
  id            String   @id @default(uuid())
  number        String   @unique
  customerId    String
  customerName  String?
  issueDate     DateTime @default(now())
  dueDate       DateTime
  amount        Float    // Subtotal
  discount      Float    @default(0)
  discountType  String   @default("Fixed") // Percentage, Fixed
  discountValue Float    @default(0)
  taxAmount     Float    @default(0)
  totalAmount   Float
  balance       Float    @default(0)
  status        String   @default("draft") // draft, sent, partial, paid, overdue, void
  items         Json?    // Array of objects
  notes         String?  @db.Text
  terms         String?  @db.Text
  orderId       String?
  payments      Payment[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@map("invoices")
}

model Payment {
  id              String    @id @default(uuid())
  receiptNumber   String    @unique
  invoiceId       String
  invoice         Invoice   @relation(fields: [invoiceId], references: [id])
  customerId      String?
  customerName    String?
  amount          Float
  date            DateTime  @default(now())
  method          String    // Cash, Bank Transfer, Credit Card, etc.
  status          String    @default("Success") // Success, Pending, Failed, Refunded, Processing
  note            String?   @db.Text
  reference       String?   // Transaction ID
  refundAmount    Float?
  refundDate      DateTime?
  refundReason    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("payments")
}

model Quotation {
  id            String   @id @default(uuid())
  number        String   @unique
  customerId    String
  customerName  String?
  title         String?
  issueDate     DateTime @default(now())
  validUntil    DateTime
  subtotal      Float    @default(0)
  discount      Float    @default(0)
  discountType  String   @default("Fixed") // Percentage, Fixed
  discountValue Float    @default(0)
  taxAmount     Float    @default(0)
  totalAmount   Float    @default(0)
  status        String   @default("Draft") // Draft, Sent, Accepted, Rejected, Expired
  items         Json?    // Array of objects
  notes         String?  @db.Text
  terms         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@map("quotations")
}

model Order {
  id            String   @id @default(uuid())
  number        String   @unique
  customerId    String
  customerName  String?
  title         String?
  issueDate     DateTime @default(now())
  deliveryDate  DateTime?
  subtotal      Float    @default(0)
  discount      Float    @default(0)
  discountType  String   @default("Fixed") // Percentage, Fixed
  discountValue Float    @default(0)
  taxAmount     Float    @default(0)
  totalAmount   Float    @default(0)
  status        String   @default("Draft") // Draft, Confirmed, Shipped, Delivered, Cancelled
  items         Json?    // Array of objects
  notes         String?  @db.Text
  terms         String?  @db.Text
  quotationId   String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@map("orders")
}

model PurchaseOrder {
  id              String   @id @default(uuid())
  number          String   @unique
  vendorId        String
  vendor          Vendor   @relation(fields: [vendorId], references: [id])
  vendorName      String?
  issueDate       DateTime @default(now())
  deliveryDate    DateTime?
  expectedDelivery DateTime?
  currency        String   @default("USD")
  subtotal        Float    @default(0)
  taxAmount       Float    @default(0)
  discountType    String   @default("Fixed") // Percentage, Fixed
  discountValue   Float    @default(0)
  discountAmount  Float    @default(0)
  totalAmount     Float    @default(0)
  status          String   @default("Draft") // Draft, Sent, Confirmed, Partially Received, Received, Cancelled
  items           PurchaseOrderItem[]
  notes           String?  @db.Text
  terms           String?  @db.Text
  bills           VendorBill[]
  receipts        GoodsReceipt[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String   @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String?
  productName     String
  description     String?
  quantity        Float    @default(1)
  receivedQuantity Float   @default(0)
  unitPrice       Float    @default(0)
  taxPercent      Float    @default(0)
  taxAmount       Float    @default(0)
  discountType    String   @default("Fixed") // Percentage, Fixed
  discountValue   Float    @default(0)
  discountAmount  Float    @default(0)
  totalAmount     Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@map("purchase_order_items")
}

model GoodsReceipt {
  id              String   @id @default(uuid())
  number          String   @unique
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  vendorId        String
  date            DateTime @default(now())
  receivedBy      String?
  notes           String?  @db.Text
  items           GoodsReceiptItem[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@map("goods_receipts")
}

model GoodsReceiptItem {
  id              String   @id @default(uuid())
  receiptId       String
  receipt         GoodsReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  purchaseOrderItemId String
  productId       String?
  productName     String
  quantity        Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@map("goods_receipt_items")
}

model VendorBill {
  id              String   @id @default(uuid())
  number          String   @unique
  vendorId        String
  vendor          Vendor   @relation(fields: [vendorId], references: [id])
  vendorName      String?
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  issueDate       DateTime @default(now())
  dueDate         DateTime
  currency        String   @default("USD")
  subtotal        Float    @default(0)
  taxAmount       Float    @default(0)
  discountAmount  Float    @default(0)
  totalAmount     Float    @default(0)
  paidAmount      Float    @default(0)
  balance         Float    @default(0)
  status          String   @default("unpaid") // unpaid, partial, paid, overdue, void
  items           VendorBillItem[]
  payments        VendorBillPayment[]
  notes           String?  @db.Text
  terms           String?  @db.Text
  createdBy       String?
  creator         User?    @relation("BillCreator", fields: [createdBy], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("vendor_bills")
}

model VendorBillItem {
  id              String    @id @default(uuid())
  billId          String
  bill            VendorBill @relation(fields: [billId], references: [id], onDelete: Cascade)
  productId       String?
  productName     String?
  description     String?
  quantity        Float     @default(1)
  unitPrice       Float     @default(0)
  taxPercent      Float     @default(0)
  taxAmount       Float     @default(0)
  discountPercent Float     @default(0)
  discountAmount  Float     @default(0)
  lineTotal       Float     @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("vendor_bill_items")
}

model VendorBillPayment {
  id              String     @id @default(uuid())
  billId          String
  bill            VendorBill @relation(fields: [billId], references: [id], onDelete: Cascade)
  amount          Float
  paymentMethod   String     // Cash, Bank Transfer, Credit Card, Check, etc.
  referenceNo     String?
  paymentDate     DateTime   @default(now())
  notes           String?    @db.Text
  createdBy       String?
  creator         User?      @relation("BillPaymentCreator", fields: [createdBy], references: [id])
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@map("vendor_bill_payments")
}

model FinanceDashboardCache {
  id          String   @id @default(uuid())
  key         String   @unique // e.g. "mtd_stats", "ytd_stats"
  value       Json
  updatedAt   DateTime @updatedAt

  @@map("finance_dashboard_cache")
}

model Currency {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  symbol    String
  rate      Float    @default(1.0)
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("currencies")
}

model TaxRate {
  id         String   @id @default(uuid())
  name       String
  rate       Float
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("tax_rates")
}

model EmailTemplate {
  id        String   @id @default(uuid())
  name      String   @unique
  subject   String
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("email_templates")
}

model AppModule {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  isEnabled   Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("app_modules")
}

model NumberSeries {
  id          String   @id @default(uuid())
  name        String   @unique
  prefix      String
  lastNumber  Int      @default(0)
  padding     Int      @default(4)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("number_series")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  module    String
  details   String?  @db.Text
  ipAddress String?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}
